# ─── LLM ───────────────────────────────────────────────────────────────────────
# Preferred provider-agnostic config:
# - For xAI: set XAI_API_KEY (or LLM_API_KEY) and LLM_BASE_URL=https://api.x.ai/v1
# - For OpenAI: set OPENAI_API_KEY (or LLM_API_KEY)
LLM_API_KEY=
XAI_API_KEY=
LLM_BASE_URL=
OPENAI_API_KEY=

# Primary model — used for all agents unless fallback is triggered
PRIMARY_MODEL=gpt-4o

# Fallback model — used on the last retry attempt after rate-limit/error
FALLBACK_MODEL=gpt-4o-mini

# ─── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1

# SQS queue URL (set by CDK deploy or LocalStack bootstrap)
SQS_QUEUE_URL=http://localhost:4566/000000000000/orchestrator-jobs

# DynamoDB table name (matches infra/cdk/lib/storage-stack.ts)
DYNAMODB_TABLE_NAME=orchestrator-runs

# ─── OpenTelemetry ─────────────────────────────────────────────────────────────
# In ECS: points to ADOT sidecar (localhost:4318)
# In local dev: points to a local OTel collector or can be disabled
OTLP_ENDPOINT=http://localhost:4318
SERVICE_NAME=multi-agent-orchestrator
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# ─── Behaviour ─────────────────────────────────────────────────────────────────
# Max Coder→Reviewer revision cycles before accepting best effort
MAX_REVISION_CYCLES=3

# Reviewer quality score threshold (0.0–1.0); below this routes back to coder
REVIEWER_QUALITY_THRESHOLD=0.7

# ─── Runtime mode ──────────────────────────────────────────────────────────────
# api    → start NestJS HTTP server
# worker → start SQS consumer loop
ORCHESTRATOR_MODE=api

# NestJS server
HOST=0.0.0.0
PORT=3000
